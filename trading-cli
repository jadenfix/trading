}

observability_location() {
  echo "${OBS_LOCATION:-us-central1}"
}

observability_control_token() {
  echo "${OBS_CONTROL_TOKEN:-local-dev-token}"
}

json_escape() {
  local input="$1"
  input="${input//\\/\\\\}"
  input="${input//\"/\\\"}"
  input="${input//$'\n'/\\n}"
  input="${input//$'\r'/\\r}"
  input="${input//$'\t'/\\t}"
  echo "$input"
}

sports_agent_control_request() {
  local method="$1"
  local endpoint="$2"
  local payload="$3"

  local curl_bin
  curl_bin="$(resolve_cmd curl || true)"
  if [[ -z "$curl_bin" ]]; then
    echo "curl is required for sports-agent control commands" >&2
    return 1
  fi

  "$curl_bin" -fsS \
    -X "$method" \
    "$(observability_api_url)$endpoint" \
    -H "authorization: Bearer $(observability_control_token)" \
    -H "content-type: application/json" \
    -d "$payload"
}

sports_agent_workflow_action() {
  local workflow_id="$1"
  local action="$2"
  local reason="$3"

  local project location request_id payload
  project="$(observability_project)"
  location="$(observability_location)"
  request_id="trading-cli-$(date +%s)-$RANDOM"
  payload="{\"actor\":\"trading-cli\",\"reason\":\"$(json_escape "$reason")\",\"requestId\":\"$(json_escape "$request_id")\"}"

  sports_agent_control_request \
    POST \
    "/v1/projects/${project}/locations/${location}/workflows/${workflow_id}:${action}" \
    "$payload"
  echo
}

sports_agent_stop_service_action() {
  local project location request_id payload
  project="$(observability_project)"
  location="$(observability_location)"
  request_id="trading-cli-$(date +%s)-$RANDOM"
  payload="{\"actor\":\"trading-cli\",\"reason\":\"manual service stop from trading-cli\",\"requestId\":\"$(json_escape "$request_id")\"}"

  sports_agent_control_request \
    POST \
    "/v1/projects/${project}/locations/${location}/services/sports-agent:stop" \
    "$payload"
  echo
}

run_sports_agent() {
  local action="${1:-go}"
  shift || true

  case "$action" in
    go|run|up|start)
      local mode="hitl"
      local dry_run_flag=0

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --mode)
            mode="${2:-}"
            shift 2
            ;;
          --dry-run)
            dry_run_flag=1
            shift
            ;;
          *)
            echo "Unknown sports-agent option: $1" >&2
            echo "Use: ./trading-cli sports-agent [go|up] [--mode <hitl|auto_ultra_strict>] [--dry-run]" >&2
            exit 1
            ;;
        esac
      done

      case "$mode" in
        hitl|auto_ultra_strict) ;;
        *)
          echo "Invalid sports-agent mode: $mode" >&2
          echo "Use --mode <hitl|auto_ultra_strict>" >&2
          exit 1
          ;;
      esac

      local cmd=(cargo run -- --mode "$mode")
      if [[ "$dry_run_flag" -eq 1 ]]; then
        cmd+=(--dry-run)
      fi

      if [[ "$action" == "up" || "$action" == "start" ]]; then
        mkdir -p "$LOG_DIR"
        if ! start_service_bg "sports-agent" "$ROOT_DIR/observability-platform/sports-agent-worker" "${cmd[@]}"; then
          exit 1
        fi
      else
        run_in_dir "$ROOT_DIR/observability-platform/sports-agent-worker" "${cmd[@]}"
      fi
      ;;
    down|stop)
      if [[ $# -gt 0 ]]; then
        echo "Too many arguments for sports-agent down command" >&2
        echo "Use: ./trading-cli sports-agent down" >&2
        exit 1
      fi
      stop_service_bg "sports-agent"
      ;;
    status)
      if [[ $# -gt 0 ]]; then
        echo "Too many arguments for sports-agent status command" >&2
        echo "Use: ./trading-cli sports-agent status" >&2
        exit 1
      fi
      service_status_line "sports-agent"
      ;;
    logs)
      if [[ $# -gt 0 ]]; then
        echo "Too many arguments for sports-agent logs command" >&2
        echo "Use: ./trading-cli sports-agent logs" >&2
        exit 1
      fi
      run_service_logs "sports-agent"
      ;;
    execute|approve)
      local workflow_id="${1:-}"
      if [[ -z "$workflow_id" ]]; then
        echo "Missing workflow/trace id. Use: ./trading-cli sports-agent execute <workflow_id_or_trace_id>" >&2
        exit 1
      fi
      if [[ $# -gt 1 ]]; then
        echo "Too many arguments for sports-agent execute command" >&2
        echo "Use: ./trading-cli sports-agent execute <workflow_id_or_trace_id>" >&2
        exit 1
      fi
      sports_agent_workflow_action "$workflow_id" "execute" "manual execute from trading-cli"
      ;;
    cancel)
      local workflow_id="${1:-}"
      if [[ -z "$workflow_id" ]]; then
        echo "Missing workflow id. Use: ./trading-cli sports-agent cancel <workflow_id_or_trace_id> [--hard]" >&2
        exit 1
      fi
      shift || true

      local hard_cancel_flag=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --hard)
            hard_cancel_flag=1
            shift
            ;;
          *)
            echo "Unknown sports-agent cancel option: $1" >&2
            echo "Use: ./trading-cli sports-agent cancel <workflow_id_or_trace_id> [--hard]" >&2
            exit 1
            ;;
        esac
      done

      if [[ "$hard_cancel_flag" -eq 1 ]]; then
        sports_agent_workflow_action "$workflow_id" "hardCancel" "manual hard cancel from trading-cli"
      else
        sports_agent_workflow_action "$workflow_id" "cancel" "manual soft cancel from trading-cli"
      fi
      ;;
    hard-cancel)
      local workflow_id="${1:-}"
      if [[ -z "$workflow_id" ]]; then
        echo "Missing workflow id. Use: ./trading-cli sports-agent hard-cancel <workflow_id_or_trace_id>" >&2
        exit 1
      fi
      if [[ $# -gt 1 ]]; then
        echo "Too many arguments for sports-agent hard-cancel command" >&2
        echo "Use: ./trading-cli sports-agent hard-cancel <workflow_id_or_trace_id>" >&2
        exit 1
      fi
      sports_agent_workflow_action "$workflow_id" "hardCancel" "manual hard cancel from trading-cli"
      ;;
    stop-service)
      if [[ $# -gt 0 ]]; then
        echo "Too many arguments for sports-agent stop-service command" >&2
        echo "Use: ./trading-cli sports-agent stop-service" >&2
        exit 1
      fi
      sports_agent_stop_service_action
      ;;
    *)
      echo "Unknown sports-agent action: $action" >&2
      echo "Use: ./trading-cli sports-agent [go|up|down|status|logs|approve|execute|cancel|hard-cancel|stop-service] [--mode <hitl|auto_ultra_strict>] [--dry-run]" >&2
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-}"
  shift || true

  if [[ -z "$cmd" ]]; then
    usage
    exit 0
  fi

  case "$cmd" in
    test)
      run_tests "${1:-all}"
      ;;
    weather)
      run_weather "$@"
      ;;
    arbitrage|arb)
      run_arbitrage "$@"
      ;;
    llm-workflow|llm)
      run_llm_workflow "$@"
      ;;
    temporal|temp)
      run_temporal "$@"
      ;;
    observability|observe|obs)
      run_observability "$@"
      ;;
    sports-agent|sports)
      run_sports_agent "$@"
      ;;
    clawdbot-trading)
      run_clawdbot_trading "$@"
      ;;
    clawdbot-trading-up)
      run_clawdbot_trading up "$@"
      ;;
    clawdbot-trading-down)
      run_clawdbot_trading down "$@"
      ;;
    clawdbot-trading-ps)
      run_clawdbot_trading ps "$@"
      ;;
    clawdbot-trading-logs)
      run_clawdbot_trading logs "$@"
      ;;
    clawdbot-trading-ping)
      run_clawdbot_trading ping "$@"
      ;;
    clawdbot-trading-status)
      run_clawdbot_trading status "$@"
      ;;
    clawdbot-trading-capabilities)
      run_clawdbot_trading capabilities "$@"
      ;;
    clawdbot-trading-doctor)
      run_clawdbot_trading doctor "$@"
      ;;
    clawdbot-trading-start)
      run_clawdbot_trading start "$@"
      ;;
    clawdbot-trading-stop)
      run_clawdbot_trading stop "$@"
      ;;
    dev)
      run_dev
      ;;
    down)
      run_down
      ;;
    status)
      run_status
      ;;
    bots)
      run_legacy_bots "${1:-}"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      local suggestion
      suggestion="$(suggest_command "$cmd" || true)"
      if [[ -n "$suggestion" ]]; then
        echo "Did you mean: ./trading-cli $suggestion" >&2
      fi
      echo >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
